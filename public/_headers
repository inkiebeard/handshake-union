# Security headers — applied to all routes by Cloudflare Pages / Workers Assets.
# To add a new external service: extend connect-src (API calls) or img-src (images).
# Do not re-enable unsafe-eval or unsafe-inline in script-src.
# See: https://developers.cloudflare.com/pages/configuration/headers/
/*
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src https: data: blob:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.giphy.com; font-src 'self' data:; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; form-action 'self'
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: no-referrer
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
